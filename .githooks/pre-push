#!/bin/bash
# Pre-push hook: Roda testes antes de permitir push
# Se os testes falharem, o push é bloqueado

echo "🧪 Rodando testes antes do push..."
echo ""

# Define PYTHONPATH
export PYTHONPATH="$(pwd)"

# Detecta python3 ou python
if command -v python3 &> /dev/null; then
    PYTHON_CMD=python3
else
    PYTHON_CMD=python
fi

# Roda os testes
$PYTHON_CMD -m pytest tests/ -v --tb=short

# Captura o exit code
TEST_EXIT_CODE=$?

echo ""

# Se os testes falharam
if [ $TEST_EXIT_CODE -ne 0 ]; then
    echo "❌ PUSH BLOQUEADO!"
    echo ""
    echo "Os testes falharam. Corrija os erros antes de fazer push."
    echo ""
    echo "Dica: rode 'pytest tests/ -v' para ver os detalhes"
    echo ""
    exit 1  # Bloqueia o push
fi

# Se os testes passaram
echo "✅ Testes OK - Push liberado!"
echo ""
exit 0  # Permite o push
